# Override discovery only when your stable /dev/serial/by-id links differ.
BADGE_DEVICE=
BADGE_DEVICE_GLOB=/dev/serial/by-id/*DC32*Flipper*
BADGE_DEVICE_FALLBACK=/dev/ttyACM0
FLIPPER_DEVICE=
FLIPPER_DEVICE_GLOB=/dev/serial/by-id/*Flipper*
FLIPPER_DEVICE_FALLBACK=/dev/ttyACM1

# Keep both USB links responsive while the Flipper emits screen frames.
TICK_MS=5
