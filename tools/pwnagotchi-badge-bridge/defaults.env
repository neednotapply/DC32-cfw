# The bridge connects only to Pwnagotchi's loopback mobile web UI.
PWN_URL=http://127.0.0.1:8080
PWN_USER=
PWN_PASSWORD=
HTTP_TIMEOUT=5

# Prefer the stable USB identity exported by the DC32 Pwnagotchi app.
DEVICE=
DEVICE_GLOB=/dev/serial/by-id/*DC32*Pwnagotchi*
DEVICE_FALLBACK=/dev/ttyACM0
TICK_MS=10
FACE_SECONDS=1
PLUGIN_REFRESH_SECONDS=5
