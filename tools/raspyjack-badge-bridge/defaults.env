# RaspyJack local surfaces. These are read/written only; no RaspyJack files are changed.
FRAME_PATH=/dev/shm/raspyjack_last.jpg
INPUT_SOCK=/dev/shm/rj_input.sock

# Prefer the stable by-id serial link. DEVICE overrides discovery when set.
DEVICE=
DEVICE_GLOB=/dev/serial/by-id/*DC32*RaspyJack*
DEVICE_FALLBACK=/dev/ttyACM0
POLL_HZ=10

# Keep serial input and partial frame writes moving while RaspyJack is rendering.
TICK_MS=5
DIAGNOSTICS_SECONDS=5

# auto chooses RGB565 plus 8x8 deltas when the badge and Pillow support it.
# Set jpeg to force the original low-dependency JPEG transport.
VIDEO_MODE=auto
